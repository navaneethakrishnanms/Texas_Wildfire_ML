# ============================================================
#  Wildfire Ignition Prediction System — .gitignore
#
#  PUSHED TO GITHUB  ✅
#    - All Python source code (.py)
#    - All config files (.py, .yaml, .json, .toml)
#    - Markdown reports and README files (.md)
#    - Small schema/summary CSVs (gate1, gate2, phase2a summaries etc.)
#    - requirements.txt / environment files
#    - Plots and images (.png, .jpg, .svg)
#
#  NOT PUSHED  ❌
#    - Raw data (NC files, TIF rasters, large CSVs)
#    - Processed parquet datasets (generated by pipeline, too large)
#    - Large CSV exports of full datasets (97 MB+)
#    - Model weight files
#    - Logs, Python cache, temp files
# ============================================================

# ── OS ARTIFACTS ─────────────────────────────────────────────
nul
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ── RAW FPA-FOD SOURCE DATA (150–190 MB each) ────────────────
V2/data/*_FPA_FOD_cons.csv
V2/data/*.xlsx
V2/data/*.xls

# ── GRIDMET NETCDF FILES (100–140 MB each, 84 files total) ───
V2/data/gridmet/
**/*.nc
**/*.nc4
**/*.hdf
**/*.hdf5
**/*.h5

# ── RASTER / GIS FILES ───────────────────────────────────────
# Note: PLACE_RASTERS_HERE.txt inside V2/data/rasters/ is kept (tracked as a guide)
V2/data/rasters/*.tif
V2/data/rasters/*.tiff
V2/data/rasters/*.geotiff
V2/data/rasters/*.img
V2/data/rasters/*.zip
**/*.tif
**/*.tiff
**/*.geotiff
**/*.img
**/*.vrt
**/*.shp
**/*.dbf
**/*.shx
**/*.prj
**/*.cpg
**/*.sbn
**/*.sbx
**/*.zip
**/*.gpkg

# ── LARGE PROCESSED DATASETS (generated by pipeline) ─────────
V2/data/processed/**/*.parquet
V2/data/raw/**/*.parquet
V2/data/**/*.parquet

# Phase 2 output parquets (large ML-ready datasets)
V2/phase2/outputs/**/*.parquet
V2/phase2/outputs/**/*.feather

# Full CSV exports of entire datasets (too large for git)
V2/phase2/outputs/**/final_training_dataset_*.csv
V2/phase2/outputs/**/train_*.csv
V2/phase2/outputs/**/val_*.csv
V2/phase2/outputs/**/test_*.csv
V2/phase2/outputs/**/sample_1000_*.csv
V2/phase2/outputs/**/gridmet_features_*.csv
V2/phase2/outputs/**/static_features_*.csv

# csv_exports folder — large full-dataset exports and sample dumps
V2/phase2/outputs/**/csv_exports/final_dataset_ALL.csv
V2/phase2/outputs/**/csv_exports/fire_all.csv
V2/phase2/outputs/**/csv_exports/final_dataset_sample_*.csv
V2/phase2/outputs/**/csv_exports/full_labels_sample_*.csv
V2/phase2/outputs/**/csv_exports/nonfire_sample_*.csv

# Phase 3 risk-map outputs (maps/ folder — large prediction CSVs + HTML)
V2/phase2/outputs/**/maps/*.csv
V2/phase2/outputs/**/maps/*.html

# ── KEEP small schema/report CSVs (human-readable, < 1MB) ────
!V2/phase2/outputs/**/gate1_removed.csv
!V2/phase2/outputs/**/gate2_removed.csv
!V2/phase2/outputs/**/feature_schema.csv
!V2/phase2/outputs/**/cleaned_feature_schema.csv
!V2/phase2/outputs/**/feature_source_map.csv
!V2/phase2/outputs/**/missing_root_cause.csv
!V2/phase2/outputs/**/production_availability.csv
!V2/phase2/outputs/**/static_dynamic_features.csv
!V2/phase2/outputs/**/h3_ecoregion_breakdown_*.csv
!V2/phase2/outputs/**/h3_grid_summary_*.csv
!V2/phase2/outputs/**/phase2c_summary.csv
!V2/phase2/outputs/**/phase2d_summary.csv

# ── MODEL WEIGHTS / SAVED MODELS ─────────────────────────────
**/*.pkl
**/*.pickle
**/*.joblib
**/*.model
**/*.bin
**/*.cbm
**/*.ubj
V2/phase2/outputs/**/models/

# ── LOGS ─────────────────────────────────────────────────────
**/*.log
V2/logs/
V2/phase2/logs/
V1/logs/

# ── PYTHON CACHE ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
.pytest_cache/
.mypy_cache/
*.pyc

# ── JUPYTER ──────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── VIRTUAL ENVIRONMENTS ──────────────────────────────────────
.env
.venv/
venv/
env/
conda-env/
*.egg-info/
dist/
build/

# ── IDE / EDITOR ─────────────────────────────────────────────
.idea/
.vscode/
*.code-workspace
*.swp
*.swo

# ── TEMP / SCRATCH ────────────────────────────────────────────
tmp/
temp/
scratch/
*.tmp
*.bak

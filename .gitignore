# ============================================================
#  Wildfire Ignition Prediction System — .gitignore
#  Push:    Code, analysis outputs (CSV/MD), plots, maps
#  Ignore:  Raw datasets, processed parquets, large binaries
# ============================================================

# ── OS ARTIFACTS ─────────────────────────────────────────────
nul
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ── RAW FPA-FOD SOURCE DATA (150–190 MB each) ────────────────
V2/data/*_FPA_FOD_cons.csv
V2/data/*.xlsx
V2/data/*.xls

# ── PROCESSED PARQUET / CSV DATASETS ─────────────────────────
# (large ML-ready datasets — too big for git)
V2/data/processed/**/*.parquet
V2/data/processed/**/*.csv
V2/data/raw/**/*.parquet
V2/data/raw/**/*.csv

# ── PHASE 2 DOWNLOADED RAW DATA (GridMET, MODIS, LANDFIRE etc.) ──
V2/data/gridmet/
V2/data/rasters/
**/*.nc
**/*.nc4
**/*.hdf
**/*.hdf5
**/*.h5

# ── PHASE 2 LARGE INTERMEDIATE DATA ──────────────────────────
# Parquet training datasets (built by pipeline, not code)
V2/phase2/outputs/**/*.parquet
V2/phase2/outputs/**/*.feather
# But KEEP the analysis CSVs and reports
!V2/phase2/outputs/**/*.csv
!V2/phase2/outputs/**/*.md

# ── RASTER / GIS FILES ───────────────────────────────────────
**/*.tif
**/*.tiff
**/*.geotiff
**/*.img
**/*.vrt
**/*.shp
**/*.dbf
**/*.shx
**/*.prj
**/*.cpg
**/*.sbn
**/*.sbx
**/*.zip

# ── MODEL WEIGHTS (large binary files) ───────────────────────
**/*.pkl
**/*.pickle
**/*.joblib
**/*.model
**/*.bin
**/*.cbm

# ── LOGS ─────────────────────────────────────────────────────
**/*.log
V2/logs/
V2/phase2/logs/
V1/logs/

# ── PYTHON CACHE ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
.pytest_cache/
.mypy_cache/
*.pyc

# ── JUPYTER ──────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── VIRTUAL ENVIRONMENTS ──────────────────────────────────────
.env
.venv/
venv/
env/
conda-env/
*.egg-info/
dist/
build/

# ── IDE / EDITOR ─────────────────────────────────────────────
.idea/
.vscode/
*.code-workspace
*.swp
*.swo

# ── TEMP / SCRATCH ────────────────────────────────────────────
tmp/
temp/
scratch/
*.tmp
*.bak

# ============================================================
#  WHAT IS TRACKED (pushed to GitHub):
#  ✅ All Python source code (.py)
#  ✅ All config files (.py, .yaml, .json, .toml)
#  ✅ All analysis outputs (phase2/outputs/**/*.csv)
#  ✅ All Markdown reports (.md)
#  ✅ All plots and images (.png, .jpg, .svg)
#  ✅ requirements.txt files
#  ✅ README files
# ============================================================

# ============================================================
#  Wildfire Ignition Prediction System — .gitignore
#  RULE: Only exclude large raw/processed DATA files.
#  Everything else (code, outputs, images, maps) IS tracked.
# ============================================================

# ── RAW FPA-FOD YEARLY CSVs (79-180 MB each) ─────────────────
V2/data/*_FPA_FOD_cons.csv
V2/data/*.xlsx
V2/data/*.xls

# ── PROCESSED DATA FILES (111-114 MB CSVs, 22 MB parquets) ──
V2/data/processed/**/*.csv
V2/data/processed/**/*.parquet

# ── V1 LARGE RASTER/GIS FILES (.tif, .tiff) ──────────────────
**/*.tif
**/*.tiff
**/*.geotiff

# ── LOGS ─────────────────────────────────────────────────────
V2/logs/*.log
V1/logs/*.log
logs/*.log
*.log

# ── PYTHON CACHE ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
.pytest_cache/
.mypy_cache/

# ── JUPYTER CHECKPOINTS ──────────────────────────────────────
.ipynb_checkpoints/

# ── ENVIRONMENT / IDE ────────────────────────────────────────
.env
.venv/
venv/
*.egg-info/
dist/
build/
.idea/
.vscode/
*.code-workspace

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
